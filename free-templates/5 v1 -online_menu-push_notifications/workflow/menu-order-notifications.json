        "contentType": "raw",
        "rawContentType": "text/plain",
        "body": "={{\n  'Nome: ' + $json.body.nome + ' | ' +\n  $json.body.ordine\n    .map(i =>\n      i.quantita + 'x ' +\n      i.nome + ' ' +\n      i.dettaglio\n    )\n    .join(' | ') +\n  '\\n🕐 ' +\n  $json.body.orario\n}}",
